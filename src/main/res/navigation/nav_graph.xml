<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/mainFragment">

    <fragment
        android:id="@+id/mainFragment"
        android:name="ci.nsu.moble.main.ui.MainFragment"
        android:label="MainFragment">
        <action
            android:id="@+id/action_mainFragment_to_stageOneFragment"
            app:destination="@id/stageOneFragment" />
        <action
            android:id="@+id/action_mainFragment_to_historyFragment"
            app:destination="@id/historyFragment" />
    </fragment>

    <fragment
        android:id="@+id/stageOneFragment"
        android:name="ci.nsu.moble.main.ui.StageOneFragment"
        android:label="StageOneFragment">
        <action
            android:id="@+id/action_stageOneFragment_to_stageTwoFragment"
            app:destination="@id/stageTwoFragment" />
    </fragment>

    <fragment
        android:id="@+id/stageTwoFragment"
        android:name="ci.nsu.moble.main.ui.StageTwoFragment"
        android:label="StageTwoFragment">
        <action
            android:id="@+id/action_stageTwoFragment_to_resultFragment"
            app:destination="@id/resultFragment" />
    </fragment>

    <fragment
        android:id="@+id/resultFragment"
        android:name="ci.nsu.moble.main.ui.ResultFragment"
        android:label="ResultFragment">
        <action
            android:id="@+id/action_resultFragment_to_mainFragment"
            app:destination="@id/mainFragment"
            app:popUpTo="@id/mainFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/historyFragment"
        android:name="ci.nsu.moble.main.ui.HistoryFragment"
        android:label="HistoryFragment">
        <action
            android:id="@+id/action_historyFragment_to_detailFragment"
            app:destination="@id/detailFragment" />
    </fragment>

    <fragment
        android:id="@+id/detailFragment"
        android:name="ci.nsu.moble.main.ui.DetailFragment"
        android:label="DetailFragment" />

</navigation>